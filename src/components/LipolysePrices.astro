---
import assessmentImage from "../assets/assessment.webp";
import { Image } from "astro:assets";
import InfoIcon from "../../public/info.svg";
---

<section id="preise-lipolyse" class="centered">
  <div>
    <h1>Richtpreise – Injektionslipolyse (pro Behandlung)</h1>
    <div class="flex-container">
      <table>
        <tbody>
          <tr>
            <td>Doppelkinn:</td>
            <td class="price">CHF 350.– bis 450.–</td>
          </tr>
          <tr>
            <td>Oberarme:</td>
            <td class="price">CHF 400.– bis 500.–</td>
          </tr>
          <tr>
            <td>Bauch / Hüften / Flanken:</td>
            <td class="price">CHF 450.– bis 650.–</td>
          </tr>
          <tr>
            <td>Oberschenkel:</td>
            <td class="price">CHF 500.– bis 700.–</td>
          </tr>
        </tbody>
      </table>
      <div style="max-width: 400px;">
        <Image
          src={assessmentImage}
          alt="Dr. Scheffbuch bei der Beratung"
          sizes="(max-width: 768px) 300px, 400px"
        />
      </div>
    </div>
    <div class="info-box">
      <InfoIcon class="info-icon" />
      <div>Für ein optimales Ergebnis sind meist mehrere Sitzungen nötig.</div>
    </div>
  </div>
</section>

<style>
  .flex-container {
    display: flex;
    gap: 4rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  table {
    max-width: 400px;
    width: 100%;
    border-radius: 16px;
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
    border: 1px solid rgba(142, 169, 228, 0.14);
    padding: 1.25rem;
    background-image: linear-gradient(
      40deg,
      var(--color--grey) 11%,
      #e5ecf91a 50%,
      var(--color--grey) 87%
    );
  }

  td {
    vertical-align: bottom;
  }

  img {
    border-radius: 1rem;
    height: 100%;
  }

  .price {
    font-weight: 700;
    text-align: right;
  }

  .info-box {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    background: #e5ecf9;
    border-left: 4px solid var(--color--primary);
    padding: 0.9rem 1.2rem;
    border-radius: 0.5rem;
    font-size: 1.05rem;
    margin-top: 2rem;
    max-width: 600px;
  }

  .info-icon {
    color: var(--color--primary);
    width: 32px;
    height: 32px;
    flex-shrink: 0;
  }
</style>
