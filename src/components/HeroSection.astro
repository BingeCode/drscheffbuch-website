---
import { Image } from "astro:assets";
import heroImage from "../assets/doctor_bw.webp";
---

<section id="start">
  <div class="hero-container">
    <div class="wrapper">
      <h1 class="title">Dr. Nicolas Scheffbuch</h1>
      <h2 class="subtitle">
        Ästhetische Medizin in St. Gallen & Mels – persönlich, präzise,
        natürlich
      </h2>
    </div>

    <div class="hero-content">
      <div class="hero-image-wrap">
        <Image
          src={heroImage}
          sizes="(max-width: 1200px) 300px, (max-width: 1400px) 400px, 500px"
          alt="A picture of Dr. Scheffbuch"
          loading="eager"
          fetchpriority="high"
        />
      </div>

      <div class="intro-text">
        <p class="services">
          Botulinumtoxin · Hyaluronfiller · Injektionslipolyse
        </p>
        <p class="description">
          Ärztliche ästhetische Behandlungen auf höchstem Niveau. Alle
          Behandlungen werden von mir, Dr. Nicolas Scheffbuch, persönlich
          durchgeführt.
        </p>

        <div class="partners">
          <p>In Kooperation mit:</p>
          <div class="partner-links">
            <a
              href="https://www.google.com/maps/search/?api=1&query=Beauty+Cosmetics+Neugasse+26+9000+St.+Gallen"
              target="_blank"
              rel="noopener">Beauty Cosmetics, St. Gallen</a
            >
            <span class="separator">•</span>
            <a
              href="https://www.google.com/maps/search/?api=1&query=House+of+Beauty+Bahnhofstrasse+23+8887+Mels"
              target="_blank"
              rel="noopener">House of Beauty, Mels</a
            >
          </div>
        </div>

        <a href="#kontakt" class="cta-button">Termin vereinbaren</a>
      </div>
    </div>
  </div>
</section>

<style>
  section {
    background-image: linear-gradient(180deg, var(--color--grey), transparent);
    padding-top: 140px;
    padding-bottom: 4rem;
  }

  .hero-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 1.5rem;
    text-align: center;
  }

  .wrapper {
    margin-bottom: 3rem;
  }
  .title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 600;
    line-height: 1.1;
    margin-bottom: 1rem;
    color: #111827;
  }
  .subtitle {
    font-size: clamp(1.2rem, 3vw, 1.8rem);
    color: #4b5563;
    font-weight: 400;
    max-width: 800px;
    margin: 0 auto;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
  }

  .hero-image-wrap {
    border: 8px solid white;
    border-radius: 50%;
    width: 280px;
    height: 280px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .intro-text {
    max-width: 600px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .services {
    font-weight: 600;
    color: var(--color--primary);
    font-size: 1.1rem;
    letter-spacing: 0.5px;
    margin: 0;
  }

  .description {
    font-size: 1.05rem;
    line-height: 1.6;
    color: #374151;
    margin: 0;
  }

  .partners {
    margin-top: 0.5rem;
  }

  .partners p {
    font-size: 0.9rem;
    color: #6b7280;
    margin-bottom: 0.5rem;
  }

  .partner-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    align-items: center;
  }

  .partner-links a {
    color: #4b5563;
    text-decoration: none;
    font-weight: 500;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s;
  }

  .partner-links a:hover {
    color: var(--color--primary);
    border-color: var(--color--primary);
  }

  .separator {
    color: #9ca3af;
  }

  .cta-button {
    margin-top: 0.5rem;
    padding: 12px 32px;
    background-color: var(--color--primary);
    color: #fff;
    text-decoration: none;
    border-radius: 500px;
    font-weight: 600;
    transition:
      transform 0.2s,
      box-shadow 0.2s;
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
  }

  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(37, 99, 235, 0.4);
    background-color: #1d4ed8;
  }

  @media screen and (max-width: 768px) {
    section {
      padding-top: 100px;
    }

    .hero-image-wrap {
      width: 240px;
      height: 240px;
    }
  }
</style>
