---
import Conversation from "../../public/conversation.svg";
import Target from "../../public/target.svg";
import Camera from "../../public/camera.svg";
import Pen from "../../public/pen.svg";
import Syringe from "../../public/syringe.svg";
import Face from "../../public/face.svg";
---

<section id="ablauf">
  <div class="centered">
    <h1>Ablauf der Behandlung</h1>

    <div class="cards-container">
      <div>
        <Conversation />
        <p>1. Persönliches Beratungsgespräch</p>
      </div>

      <div>
        <Target />
        <p>2. Gemeinsame Besprechung der Wunschzonen</p>
      </div>

      <div>
        <Camera />
        <p>3. Foto-Dokumentation vor der Behandlung</p>
      </div>

      <div>
        <Pen />
        <p>4. Desinfektion &amp; Einzeichnung</p>
      </div>

      <div>
        <Syringe />
        <p>5. Injektion mit besonders feinen 33G-Nadeln</p>
      </div>

      <div>
        <Face />
        <p>6. Kurze Nachbeobachtung, anschliessend direkt gesellschaftsfähig</p>
      </div>
    </div>
  </div>
</section>

<style>
  .cards-container {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 1.5rem;
    justify-content: center;
    max-width: 1000px;
  }

  .cards-container > div {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1.5rem 1rem;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    width: 160px;
    background: #fff;
    border: 1px solid #f3f4f6;
    transition: transform 0.2s;
  }

  .cards-container > div:hover {
    transform: translateY(-4px);
  }

  @media (max-width: 768px) {
    .cards-container {
      gap: 1rem;
    }
    .cards-container > div {
      width: 45%;
    }
  }

  p {
    text-align: center;
    margin: 1rem 0 0;
    font-size: 0.95rem;
    line-height: 1.4;
  }

  img,
  svg {
    width: 48px;
    height: 48px;
    color: var(--color--primary);
  }
</style>
