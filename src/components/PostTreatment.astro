---
import Sleep from "../../public/sleep.svg";
import Gym from "../../public/gym.svg";
import Sun from "../../public/sun.svg";
import Paint from "../../public/paint.svg";
import Beer from "../../public/beer.svg";
import Face from "../../public/face.svg";
---

<section id="nachsorge">
  <div class="wrapper">
    <h2 class="title" style="text-align: center; margin-bottom: 0.5rem;">
      Nach der Behandlung
    </h2>
    <p
      class="intro"
      style="text-align: center; margin-bottom: 2rem; color: #6b7280;">
      Um das bestmögliche Ergebnis zu erzielen, beachten Sie bitte folgende
      Hinweise:
    </p>

    <div class="timeline">
      <div class="timeline-group">
        <h3 class="time-label">0–4 Stunden</h3>
        <div class="cards-grid">
          <div class="card">
            <div class="icon-box">
              <Sleep />
              <div class="forbidden-line"></div>
            </div>
            <span>Nicht hinlegen</span>
          </div>
          <div class="card">
            <div class="icon-box">
              <Face />
              <div class="forbidden-line"></div>
            </div>
            <span>Nicht massieren</span>
          </div>
        </div>
      </div>

      <div class="timeline-group">
        <h3 class="time-label">Am Behandlungstag</h3>
        <div class="cards-grid">
          <div class="card">
            <div class="icon-box">
              <Paint />
              <div class="forbidden-line"></div>
            </div>
            <span>Kein Make-up</span>
          </div>
          <div class="card">
            <div class="icon-box">
              <Beer />
              <div class="forbidden-line"></div>
            </div>
            <span>Kein Alkohol</span>
          </div>
        </div>
      </div>

      <div class="timeline-group">
        <h3 class="time-label">24 Stunden</h3>
        <div class="cards-grid">
          <div class="card">
            <div class="icon-box">
              <Gym />
              <div class="forbidden-line"></div>
            </div>
            <span>Kein Sport</span>
          </div>
          <div class="card">
            <div class="icon-box">
              <Sun />
              <div class="forbidden-line"></div>
            </div>
            <span>Keine Sauna/Solarium</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .wrapper {
    max-width: 900px;
    margin: 0 auto;
  }

  .title {
    font-size: 2rem;
    color: #111827;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .timeline-group {
    background: white;
    padding: 1.5rem;
    border-radius: 16px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    border: 1px solid #f3f4f6;
  }

  .time-label {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color--primary);
    margin: 0 0 1rem 0;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #eff6ff;
  }

  .cards-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    flex: 1 1 200px; /* Flex-grow, Flex-shrink, Basis */
  }

  .icon-box {
    position: relative;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: white;
    border-radius: 50%;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
    flex-shrink: 0;
  }

  /* Inherit svg styles or set them if needed, keeping it simple as before */
  .icon-box :global(svg) {
    width: 20px;
    height: 20px;
    color: #4b5563;
  }

  .forbidden-line {
    position: absolute;
    width: 70%;
    height: 2px;
    background: #ef4444;
    transform: rotate(45deg);
    top: 50%;
    left: 15%;
    margin-top: -1px;
    border-radius: 1px;
    box-shadow: 0 0 2px white;
  }

  span {
    font-weight: 500;
    color: #374151;
    font-size: 0.95rem;
  }

  @media (min-width: 768px) {
    .timeline {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
